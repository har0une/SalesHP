<!-- 1. Header Section -->
<div class="flex flex-col lg:flex-row lg:justify-between lg:items-center gap-6 mb-10">
  <div>
    <h1 class="text-4xl font-display font-black tracking-tight bg-gradient-to-r from-purple-600 to-emerald-600 bg-clip-text text-transparent">
      Dashboard Ops
    </h1>
    <p class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em] mt-1 ml-1">Real-time Performance Sync</p>
  </div>
  <div class="glass-style rounded-2xl px-6 py-3 flex items-center gap-3">
    <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
    <span class="text-sm font-bold text-gray-800 dark:text-gray-200 tabular-nums tracking-wider">
      <%= Time.current.strftime("%H:%M:%S") %>
    </span>
  </div>
</div>

<!-- 2. Strategy Advisory Banner -->
<div class="glass-style rounded-3xl p-6 border-2 mb-10 relative overflow-hidden group transition-all" 
     style="border-color: <%= @mission[:type] == :urgent ? 'rgba(239, 68, 68, 0.3)' : (@mission[:type] == :warning ? 'rgba(245, 158, 11, 0.3)' : 'rgba(168, 85, 247, 0.3)') %>; 
            background: <%= @mission[:type] == :urgent ? 'rgba(239, 68, 68, 0.05)' : (@mission[:type] == :warning ? 'rgba(245, 158, 11, 0.05)' : 'rgba(168, 85, 247, 0.05)') %>">
  <div class="flex items-start gap-5 relative z-10">
    <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl <%= @mission[:type] == :urgent ? 'bg-red-500/20' : (@mission[:type] == :warning ? 'bg-amber-500/20' : 'bg-purple-500/20') %>">
      <%= @mission[:icon] %>
    </div>
    <div class="flex-1">
      <div class="flex flex-wrap gap-2 mb-2">
        <span class="px-3 py-1 glass-style rounded-full text-[10px] font-black tracking-widest uppercase text-emerald-600 dark:text-emerald-400">
          💡 <%= @recommendation %>
        </span>
        <% if @mission[:type] == :urgent %>
          <span class="px-3 py-1 bg-red-500/20 rounded-full text-[10px] font-black tracking-widest uppercase text-red-600 animate-pulse">
            Urgent Mission
          </span>
        <% end %>
      </div>
      <h3 class="text-lg font-display font-black text-gray-800 dark:text-white mb-1">
        <%= @mission[:title] %>
      </h3>
      <p class="text-xs text-gray-500 font-medium">
        <%= @mission[:description] %>
      </p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">
  <!-- 3. HP & XP Panel -->
  <div class="glass-style rounded-3xl p-8 flex flex-col justify-between">
    <div class="space-y-8">
      <!-- HP Bar -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
            <span class="text-xs font-black tracking-widest text-gray-500 uppercase">HP Status</span>
          </div>
          <span class="text-xs font-black text-emerald-500">100 / 100</span>
        </div>
        <div class="w-full h-4 bg-gray-200 dark:bg-gray-800/50 rounded-full overflow-hidden p-0.5">
          <div class="h-full bg-gradient-to-r from-emerald-500 to-teal-500 rounded-full transition-all duration-1000 shadow-lg" style="width: 100%"></div>
        </div>
      </div>
      
      <!-- XP Bar -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-purple-500"></span>
            <span class="text-xs font-black tracking-widest text-gray-500 uppercase">Progression</span>
          </div>
          <div class="text-right">
            <span class="text-xs font-black text-purple-500"><%= @user.total_xp %> / <%= @user.next_rank_xp_threshold %> XP</span>
            <p class="text-[9px] font-black text-gray-400">NEXT: <%= @user.next_rank_name %></p>
          </div>
        </div>
        <div class="w-full h-4 bg-gray-200 dark:bg-gray-800/50 rounded-full overflow-hidden p-0.5 shadow-inner">
          <div class="h-full bg-gradient-to-r from-purple-500 to-indigo-500 rounded-full transition-all duration-1000 shadow-lg" style="width: <%= @user.xp_progress_pct %>%"></div>
        </div>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-between pt-6 border-t border-white/10">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-indigo-500 rounded-2xl flex items-center justify-center shadow-xl shadow-purple-500/20">
          <span class="text-xl font-black text-white text-center leading-tight">RANK<br><%= (@user.rank || "E").split(" ").first %></span>
        </div>
        <div>
          <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Active Title</p>
          <p class="text-lg font-display font-black text-gray-800 dark:text-gray-100"><%= @user.rank || "Rookie" %></p>
        </div>
      </div>
      <div class="text-right">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Streak</p>
        <p class="text-3xl font-black text-orange-500 italic tracking-tighter">🔥 <%= @user.current_streak.to_s.rjust(2, '0') %></p>
        <% if @user.current_streak > 1 %>
          <p class="text-[9px] font-bold text-gray-500 uppercase tracking-tighter mt-1">Avg ₦<%= number_to_human(@user.average_revenue_during_streak, units: { thousand: 'k' }) %>/day</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 4. Stats Mini-Grid (4 Cards) -->
  <div class="grid grid-cols-2 gap-4">
    <!-- Estimated Completion Card -->
    <div class="glass-style rounded-3xl p-6 group hover:scale-[1.02] transition-all">
      <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-indigo-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
         <span class="text-xl">🎯</span>
      </div>
      <h3 class="text-3xl font-display font-black tracking-tighter mb-1"><%= @projected_pct %>%</h3>
      <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Est. Completion</p>
    </div>
    <!-- Variance Card -->
    <div class="glass-style rounded-3xl p-6 group hover:scale-[1.02] transition-all">
      <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
         <span class="text-xl">⚡</span>
      </div>
      <h3 class="text-3xl font-display font-black tracking-tighter mb-1 <%= @variance >= 0 ? 'text-emerald-500' : 'text-red-500' %>">
        <%= @variance > 0 ? '+' : '' %><%= @variance %>%
      </h3>
      <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Growth Variance</p>
    </div>
    <!-- Avg Deal Card -->
    <div class="glass-style rounded-3xl p-6 group hover:scale-[1.02] transition-all">
      <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
         <span class="text-xl">💰</span>
      </div>
      <h3 class="text-3xl font-display font-black tracking-tighter mb-1 font-mono text-sm lg:text-3xl">
        ₦<%= number_to_human(@avg_deal, units: { thousand: 'k', million: 'm' }) %>
      </h3>
      <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Avg Deal Size</p>
    </div>
    <!-- Active Days Card -->
    <div class="glass-style rounded-3xl p-6 group hover:scale-[1.02] transition-all">
      <div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-red-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
         <span class="text-xl">📅</span>
      </div>
      <h3 class="text-3xl font-display font-black tracking-tighter mb-1"><%= @best_day[0..2] %></h3>
      <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Best Revenue Day</p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
  <!-- 5. Method Effectiveness Panel -->
  <div class="glass-style rounded-3xl p-8">
    <h3 class="text-lg font-display font-black tracking-tight mb-8 flex items-center gap-3">
      Method Effectiveness
      <span class="text-[10px] font-black text-purple-500 bg-purple-500/10 px-3 py-1 rounded-full uppercase"><%= @strength %></span>
    </h3>
    <div class="space-y-8">
      <% @effectiveness.each do |eff| %>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-black uppercase text-gray-600 dark:text-gray-400 tracking-wider"><%= eff[:name] %></span>
            <span class="text-xs font-black text-<%= eff[:name] == 'referral' ? 'emerald' : 'purple' %>-500 tabular-nums">₦<%= number_to_human(eff[:revenue], units: { thousand: 'k', million: 'm' }) %> Revenue</span>
          </div>
          <div class="w-full h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
            <div class="h-full bg-<%= eff[:name] == 'referral' ? 'emerald' : 'purple' %>-500 rounded-full" style="width: <%= eff[:percentage] %>%"></div>
          </div>
          <div class="flex gap-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
            <span><%= eff[:deals] %> Deals</span>
            <span class="text-gray-200 dark:text-gray-700">|</span>
            <span>Avg: ₦<%= number_to_human(eff[:avg_deal], units: { thousand: 'k' }) %></span>
          </div>
        </div>
      <% end %>
      <% if @effectiveness.empty? %>
        <div class="py-12 text-center">
          <p class="text-xs font-black text-gray-400 uppercase tracking-widest">Waiting for data sync...</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 6. Performance Logs -->
  <div class="glass-style rounded-3xl p-8">
    <div class="flex items-center justify-between mb-8">
      <h3 class="text-lg font-display font-black tracking-tight">Performance Logs</h3>
      <button class="text-[10px] font-black text-purple-500 hover:underline uppercase tracking-widest">Sync History</button>
    </div>
    <div class="space-y-3">
      <% @recent_sales.each do |sale| %>
        <div class="flex items-center justify-between p-4 glass-style rounded-2xl bg-white/5 group hover:bg-white/10 transition-all border-none">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-lg">
              <%= sale.method == 'referral' ? '🔗' : '👤' %>
            </div>
            <div>
              <p class="text-sm font-black text-gray-800 dark:text-gray-100 tracking-tight">₦<%= number_with_delimiter(sale.amount.to_i) %> Closed</p>
              <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">
                <%= sale.method %> • <%= sale.created_at.strftime("%I:%M %p") %>
              </p>
            </div>
          </div>
          <span class="text-xs font-black text-purple-600 dark:text-purple-400 bg-purple-500/10 px-3 py-1.5 rounded-xl">+<%= sale.xp_earned %> XP</span>
        </div>
      <% end %>
      <% if @recent_sales.empty? %>
        <div class="py-12 text-center">
          <p class="text-xs font-black text-gray-400 uppercase tracking-widest">No Recent Transmissions</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- 7. Quick Post Modal (Floating Button for mobile/desktop toggle) -->
<div class="fixed bottom-10 right-10 z-50">
  <button onclick="document.getElementById('post-modal').classList.toggle('hidden')" class="w-16 h-16 bg-gradient-to-br from-purple-600 to-indigo-600 rounded-3xl shadow-2xl shadow-purple-600/30 text-white text-3xl font-bold flex items-center justify-center hover:scale-110 active:scale-95 transition-all">
    +
  </button>
</div>

<!-- Simple Hidden Form Section for Quick Logging -->
<div id="post-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-6 bg-gray-900/50 backdrop-blur-md">
  <div class="glass-strong-style w-full max-w-lg rounded-[2.5rem] p-10 relative">
    <button onclick="document.getElementById('post-modal').classList.add('hidden')" class="absolute top-8 right-8 text-gray-500 hover:text-white text-2xl">×</button>
    <h4 class="text-2xl font-display font-black text-gray-800 dark:text-white mb-8">Post Sales Transaction</h4>
    <%= form_with model: SalesEntry.new, url: sales_entries_path, class: "space-y-6" do |f| %>
      <%= f.hidden_field :goal_id, value: @goal&.id %>
      <div class="space-y-2">
        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Receipt Amount</label>
        <%= f.number_field :amount, placeholder: "50,000", class: "w-full bg-white/10 border-white/20 rounded-2xl px-6 py-4 text-lg font-black focus:ring-4 focus:ring-purple-500/20 text-gray-800 dark:text-white outline-none", required: true %>
      </div>
      <div class="space-y-2">
        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Method Channel</label>
        <%= f.select :method, [['Direct', 'direct'], ['Referral', 'referral']], {}, class: "w-full bg-white/10 dark:bg-gray-800 border-white/20 rounded-2xl px-6 py-4 text-sm font-bold focus:ring-4 focus:ring-purple-500/20 text-gray-800 dark:text-white outline-none" %>
      </div>
      <%= f.submit "AUTHORIZE LOG ENTRY", class: "w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-[10px] font-black py-5 rounded-2xl shadow-xl shadow-purple-600/20 hover:scale-[1.02] transition-all cursor-pointer uppercase tracking-widest" %>
    <% end %>
  </div>
</div>
