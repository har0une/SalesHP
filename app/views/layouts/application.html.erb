<!DOCTYPE html>
<html class="h-full scroll-smooth">
  <head>
    <title>SalesHP | Level Up Your Sales</title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full font-sans antialiased text-gray-800 dark:text-gray-100 bg-gradient-to-br from-purple-50 via-blue-50 to-teal-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900 transition-colors duration-500">
    
    <!-- Background Animated Blobs -->
    <div class="fixed inset-0 opacity-40 pointer-events-none overflow-hidden select-none z-0">
      <div class="absolute top-0 left-0 w-72 h-72 bg-purple-300 dark:bg-purple-900/50 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
      <div class="absolute top-0 right-0 w-72 h-72 bg-emerald-200 dark:bg-emerald-900/50 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-blue-300 dark:bg-blue-900/50 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-4000"></div>
    </div>

    <div class="relative z-10 flex min-h-screen">
      
      <!-- SalesHP Sidebar -->
      <aside class="hidden lg:flex flex-col w-64 glass-strong-style border-r border-white/20 fixed inset-y-0 z-50">
        <!-- Logo Section -->
        <div class="p-6 border-b border-white/20">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-emerald-500 rounded-xl shadow-lg flex items-center justify-center text-white font-black">HP</div>
            <div>
              <h1 class="text-lg font-display font-bold text-gray-800 dark:text-gray-100 leading-tight">SalesHP</h1>
              <p class="text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest">Level Up</p>
            </div>
          </div>
        </div>
        
        <!-- Navigation -->
        <nav class="flex-1 p-4 space-y-2">
          <%= link_to root_path, class: "w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-gradient-to-r from-purple-500 to-emerald-500 text-white font-bold text-xs shadow-lg shadow-purple-500/20 transition-all hover:scale-[1.02]" do %>
            <span>DASHBOARD</span>
          <% end %>
          <%= link_to orders_path, class: "w-full flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-white/20 font-bold text-xs transition-all uppercase" do %>
            <span>Orders</span>
          <% end %>
          <%= link_to analytics_path, class: "w-full flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-white/20 font-bold text-xs transition-all uppercase" do %>
            <span>Stats</span>
          <% end %>
        </nav>


        <!-- Theme Toggle (Simplified for Rails context) -->
        <div class="p-4 border-t border-white/20 flex items-center justify-between">
          <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Theme</span>
          <button onclick="document.documentElement.classList.toggle('dark')" class="w-10 h-5 bg-gray-200 dark:bg-gray-700 rounded-full relative transition-colors">
            <div class="absolute top-0.5 left-0.5 dark:left-5 w-4 h-4 bg-white rounded-full transition-all shadow-sm"></div>
          </button>
        </div>
      </aside>

      <!-- Main Content Area -->
      <main class="flex-1 lg:pl-64 flex flex-col min-w-0 h-screen overflow-y-auto bg-transparent">
        <div class="max-w-5xl w-full mx-auto p-4 lg:p-10 pb-32 lg:pb-10">
          
          <!-- Flash Messages in Glass -->
          <% if notice %>
            <div class="mb-8 p-4 glass-style rounded-2xl border-emerald-500/30 text-emerald-600 dark:text-emerald-400 text-xs font-bold flex justify-between">
              <%= notice %>
              <button onclick="this.parentElement.remove()" class="opacity-50 hover:opacity-100">×</button>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>

      <!-- Mobile Nav for SalesHP -->
      <nav class="lg:hidden fixed bottom-0 left-0 right-0 z-40 glass-strong-style border-t border-white/20 pb-safe">
        <div class="flex justify-around items-center h-16 px-4">
          <%= link_to root_path, class: "flex items-center gap-1 text-purple-600" do %>
            <span class="text-[10px] font-black uppercase tracking-widest">Dash</span>
          <% end %>
          <button onclick="document.getElementById('post-modal').classList.toggle('hidden')" class="w-10 h-10 bg-gradient-to-br from-purple-500 to-emerald-500 rounded-xl shadow-lg -mt-8 flex items-center justify-center text-white">+</button>
          <%= link_to orders_path, class: "text-gray-500 text-[10px] font-black uppercase tracking-widest" do %>
            <span>Orders</span>
          <% end %>
        </div>
      </nav>

    </div>

    <!-- 7. Quick Post Modal (Global) -->
    <div class="fixed bottom-10 right-10 z-50 hidden lg:block">
      <button onclick="document.getElementById('post-modal').classList.toggle('hidden')" class="w-16 h-16 bg-gradient-to-br from-purple-600 to-indigo-600 rounded-3xl shadow-2xl shadow-purple-600/30 text-white text-3xl font-bold flex items-center justify-center hover:scale-110 active:scale-95 transition-all">
        +
      </button>
    </div>

    <div id="post-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-6 bg-gray-900/50 backdrop-blur-md">
      <div class="glass-strong-style w-full max-w-lg rounded-[2.5rem] p-10 relative">
        <button onclick="document.getElementById('post-modal').classList.add('hidden')" class="absolute top-8 right-8 text-gray-500 hover:text-white text-2xl">×</button>
        <h4 class="text-2xl font-display font-black text-gray-800 dark:text-white mb-8">Post Sales Transaction</h4>
        <%= form_with model: SalesEntry.new, url: sales_entries_path, class: "space-y-6" do |f| %>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Assigned Mission</label>
            <%= f.select :goal_id, @user.goals.where(active: true).map { |g| [g.title, g.id] }, { selected: (@goal&.id || @user.master_ledger.id) }, class: "w-full bg-white/10 dark:bg-gray-800 border-white/20 rounded-2xl px-6 py-4 text-sm font-bold focus:ring-4 focus:ring-purple-500/20 text-gray-800 dark:text-white outline-none" %>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Receipt Amount</label>
            <%= f.number_field :amount, placeholder: "50,000", class: "w-full bg-white/10 border-white/20 rounded-2xl px-6 py-4 text-lg font-black focus:ring-4 focus:ring-purple-500/20 text-gray-800 dark:text-white outline-none", required: true %>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Method Channel</label>
            <% if @user.sales_methods.count > 1 %>
              <%= f.select :method, @user.sales_methods.map { |m| [m.to_s.titleize, m] }, {}, class: "w-full bg-white/10 dark:bg-gray-800 border-white/20 rounded-2xl px-6 py-4 text-sm font-bold focus:ring-4 focus:ring-purple-500/20 text-gray-800 dark:text-white outline-none" %>
            <% else %>
              <% method_name = @user.sales_methods.first || 'Direct' %>
              <%= f.hidden_field :method, value: method_name %>
              <div class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-sm font-bold text-gray-400">
                Fixed Channel: <%= method_name.titleize %>
              </div>
            <% end %>
          </div>
          <%= f.submit "AUTHORIZE LOG ENTRY", class: "w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-[10px] font-black py-5 rounded-2xl shadow-xl shadow-purple-600/20 hover:scale-[1.02] transition-all cursor-pointer uppercase tracking-widest" %>
        <% end %>
      </div>
    </div>
  </body>
</html>
