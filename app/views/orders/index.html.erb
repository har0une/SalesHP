<div class="flex flex-col gap-8">
  <!-- 1. Header -->
  <div class="flex flex-col lg:flex-row lg:justify-between lg:items-end gap-6">
    <div>
      <h1 class="text-4xl font-display font-black tracking-tight bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent">
        Sales Records
      </h1>
      <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] mt-1 ml-1">Universal Transaction Ledger</p>
    </div>
    
    <div class="flex gap-4">
      <div class="glass-style rounded-2xl px-5 py-3 border-l-4 border-emerald-500">
        <p class="text-[9px] font-black text-gray-400 uppercase mb-1">Total Entries</p>
        <p class="text-sm font-black text-emerald-500 font-mono"><%= @records.count %></p>
      </div>
      <div class="glass-style rounded-2xl px-5 py-3 border-l-4 border-purple-500">
        <p class="text-[9px] font-black text-gray-400 uppercase mb-1">Net XP Generated</p>
        <p class="text-sm font-black text-purple-500 font-mono"><%= @records.sum(:xp_earned) %></p>
      </div>
    </div>
  </div>

  <!-- 2. Records List -->
  <div class="glass-style rounded-[2.5rem] p-6 lg:p-10 border border-white/10 relative overflow-hidden">
    <!-- Subtle Background Detail -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-purple-500/5 filter blur-3xl pointer-events-none rounded-full"></div>

    <div class="relative z-10 overflow-x-auto">
      <table class="w-full border-separate border-spacing-y-4">
        <thead>
          <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-left">
            <th class="px-6 pb-2">Timestamp</th>
            <th class="pb-2">Details</th>
            <th class="pb-2">Method</th>
            <th class="pb-2">Revenue</th>
            <th class="pb-2 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="text-sm">
          <% @records.each do |record| %>
            <tr class="glass-style group transition-all hover:bg-white/5 bg-white/2 rounded-2xl">
              <td class="px-6 py-6 first:rounded-l-2xl border-l-[1px] border-white/5">
                <p class="text-xs font-black text-gray-800 dark:text-gray-100"><%= record.created_at.strftime("%b %d, %Y") %></p>
                <p class="text-[9px] font-bold text-gray-400 uppercase tracking-tighter"><%= record.created_at.strftime("%I:%M %p") %></p>
              </td>
              <td class="py-6">
                <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-1">Goal Reference</p>
                <p class="text-xs font-bold text-gray-700 dark:text-gray-300"><%= record.goal.title %></p>
              </td>
              <td class="py-6">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl <%= (record.method == @user.sales_methods.first) ? 'bg-purple-500/10 text-purple-500' : 'bg-emerald-500/10 text-emerald-500' %>">
                   <span class="text-sm"><%= record.method == @user.sales_methods.first ? '👤' : '📡' %></span>
                   <span class="text-[10px] font-black uppercase tracking-widest"><%= record.method %></span>
                </div>
              </td>
              <td class="py-6 font-mono font-black text-gray-900 dark:text-white">
                ₦<%= number_with_delimiter(record.amount.to_i) %>
              </td>
              <td class="px-6 py-6 last:rounded-r-2xl text-right border-r-[1px] border-white/5">
                <%= button_to "Void", sales_entry_path(record), method: :patch, class: "text-[10px] font-black uppercase tracking-widest text-red-500 px-4 py-2 rounded-xl bg-red-500/10 hover:bg-red-500/20 transition-all", data: { turbo_confirm: "Are you sure? This cannot be undone." } %>
              </td>
            </tr>
          <% end %>
          
          <% if @records.empty? %>
            <tr>
              <td colspan="5" class="py-32 text-center">
                <div class="flex flex-col items-center gap-4 opacity-30">
                  <span class="text-4xl">📭</span>
                  <p class="text-xs font-black uppercase tracking-[0.3em]">No sales recorded yet</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
