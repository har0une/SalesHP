<!-- 1. Header Section -->
<div class="flex flex-col lg:flex-row lg:justify-between lg:items-center gap-6 mb-10">
  <div>
    <h1 class="text-4xl font-display font-black tracking-tight bg-gradient-to-r from-purple-600 to-emerald-600 bg-clip-text text-transparent">
      Dashboard
    </h1>
    <p class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em] mt-1 ml-1">Real-time Performance Sync</p>
  </div>
  <div class="glass-style rounded-2xl px-6 py-3 flex items-center gap-3">
    <div class="w-2 h-2 bg-purple-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(168,85,247,0.5)]"></div>
    <span class="text-xs font-black text-purple-600 dark:text-purple-400 uppercase tracking-widest">
      <%= @user.rank %>
    </span>
  </div>
</div>

<!-- 2.5 Revenue Snapshot Grid -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
  <% [
    ['Today', @revenue_today, 'from-emerald-500 to-teal-400', '📅'],
    ['Month', @revenue_month, 'from-purple-500 to-pink-400', '🗓️'],
    ['Life-time', @revenue_total, 'from-blue-500 to-indigo-400', '🏆']
  ].each do |label, amount, gradient, icon| %>
    <%= link_to analytics_path, class: "glass-style rounded-3xl p-5 group transition-all hover:scale-[1.02] border-none" do %>
      <div class="flex items-center gap-3 mb-3">
        <div class="w-8 h-8 rounded-xl bg-gradient-to-br <%= gradient %> flex items-center justify-center text-sm shadow-lg shadow-emerald-500/10"><%= icon %></div>
        <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest"><%= label %></span>
      </div>
      <h3 class="text-xl font-display font-black tracking-tighter tabular-nums text-gray-800 dark:text-white">
        ₦<%= number_to_human(amount, units: { thousand: 'k', million: 'm' }) %>
      </h3>
    <% end %>
  <% end %>
  
  <!-- "View Analytics" Shortcut -->
  <%= link_to analytics_path, class: "glass-style rounded-3xl p-5 group transition-all hover:scale-[1.02] flex flex-col justify-center items-center border-2 border-dashed border-gray-200 dark:border-white/10 opacity-60 hover:opacity-100" do %>
    <span class="text-[10px] font-black text-gray-500 dark:text-gray-400 uppercase tracking-widest text-center mb-1 line-clamp-1">Full Record Details</span>
    <span class="text-xs font-bold text-purple-500">View Stats →</span>
  <% end %>
</div>


<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">
  <!-- 3. HP & XP Panel -->
  <div class="glass-style rounded-3xl p-8 flex flex-col justify-between">
    <div class="space-y-8">
      <!-- HP Bar -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
            <span class="text-xs font-black tracking-widest text-gray-500 uppercase">HP Status</span>
          </div>
          <span class="text-xs font-black text-emerald-500">100 / 100</span>
        </div>
        <div class="w-full h-4 bg-gray-200 dark:bg-gray-800/50 rounded-full overflow-hidden p-0.5">
          <div class="h-full bg-gradient-to-r from-emerald-500 to-teal-500 rounded-full transition-all duration-1000 shadow-lg" style="width: 100%"></div>
        </div>
      </div>
      
      <!-- XP Bar -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-purple-500"></span>
            <span class="text-xs font-black tracking-widest text-gray-500 uppercase">Progression</span>
          </div>
          <div class="text-right">
            <span class="text-xs font-black text-purple-500"><%= @user.total_xp %> / <%= @user.next_rank_xp_threshold %> XP</span>
            <p class="text-[9px] font-black text-gray-400">NEXT: <%= @user.next_rank_name %></p>
          </div>
        </div>
        <div class="w-full h-4 bg-gray-200 dark:bg-gray-800/50 rounded-full overflow-hidden p-0.5 shadow-inner">
          <div class="h-full bg-gradient-to-r from-purple-500 to-indigo-500 rounded-full transition-all duration-1000 shadow-lg" style="width: <%= @user.xp_progress_pct %>%"></div>
        </div>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-end pt-6 border-t border-white/10">
      <div class="text-right">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Streak</p>
        <p class="text-3xl font-black text-orange-500 italic tracking-tighter">🔥 <%= @user.current_streak.to_s.rjust(2, '0') %></p>
        <% if @user.current_streak > 1 %>
          <p class="text-[9px] font-bold text-gray-500 uppercase tracking-tighter mt-1">Avg ₦<%= number_to_human(@user.average_revenue_during_streak, units: { thousand: 'k' }) %>/day</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 4. Stats Mini-Grid -->
  <div class="grid grid-cols-2 gap-4">
    <!-- Estimated Progress Card -->
    <div class="glass-style rounded-3xl p-6 group hover:scale-[1.02] transition-all">
      <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-indigo-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
         <span class="text-xl">🎯</span>
      </div>
      <h3 class="text-3xl font-display font-black tracking-tighter mb-1"><%= @projected_pct %>%</h3>
      <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Momentum Growth</p>
    </div>
    <!-- Variance Card -->
    <div class="glass-style rounded-3xl p-6 group hover:scale-[1.02] transition-all">
      <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
         <span class="text-xl">⚡</span>
      </div>
      <h3 class="text-3xl font-display font-black tracking-tighter mb-1 <%= @variance >= 0 ? 'text-emerald-500' : 'text-red-500' %>">
        <%= @variance > 0 ? '+' : '' %><%= @variance %>%
      </h3>
      <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Growth Variance</p>
    </div>

    <!-- Avg Deal Card -->
    <div class="glass-style rounded-3xl p-6 group hover:scale-[1.02] transition-all">
      <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
         <span class="text-xl">💰</span>
      </div>
      <h3 class="text-3xl font-display font-black tracking-tighter mb-1 font-mono">
        ₦<%= number_to_human(@avg_deal, units: { thousand: 'k', million: 'm' }) %>
      </h3>
      <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Avg Deal Size</p>
    </div>
    <!-- Active Days Card -->
    <div class="glass-style rounded-3xl p-6 group hover:scale-[1.02] transition-all">
      <div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-red-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
         <span class="text-xl">📅</span>
      </div>
      <h3 class="text-3xl font-display font-black tracking-tighter mb-1"><%= @best_day[0..2] %></h3>
      <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Best Revenue Day</p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
<% if @user.sales_methods.count > 1 %>
  <!-- 5. Method Effectiveness Panel -->
  <div class="glass-style rounded-3xl p-8">
    <h3 class="text-lg font-display font-black tracking-tight mb-8 flex items-center gap-3">
      Channel Effectiveness
      <span class="text-[10px] font-black text-purple-500 bg-purple-500/10 px-3 py-1 rounded-full uppercase"><%= @strength %></span>
    </h3>
    <div class="space-y-8">
      <% @effectiveness.each do |eff| %>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-black uppercase text-gray-600 dark:text-gray-400 tracking-wider"><%= eff[:name] %></span>
            <span class="text-xs font-black text-purple-500 tabular-nums">₦<%= number_to_human(eff[:revenue], units: { thousand: 'k', million: 'm' }) %> Revenue</span>
          </div>
          <div class="w-full h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-purple-500 to-emerald-500 rounded-full" style="width: <%= eff[:percentage] %>%"></div>
          </div>
          <div class="flex gap-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
            <span><%= eff[:deals] %> Deals</span>
            <span class="text-gray-200 dark:text-gray-700">|</span>
            <span>Avg: ₦<%= number_to_human(eff[:avg_deal], units: { thousand: 'k' }) %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

  <!-- 6. Performance Logs -->
  <div class="glass-style rounded-3xl p-8">
    <div class="flex items-center justify-between mb-8 pb-4 border-b border-purple-500/30">
      <div>
        <h3 class="text-lg font-display font-black tracking-tight">Performance Logs</h3>
        <p class="text-[9px] font-black text-purple-500 uppercase tracking-widest">Showing last 5 entries</p>
      </div>
      <%= link_to analytics_path, style: "background: #9333ea; color: white; padding: 12px 24px; border-radius: 12px; font-size: 10px; font-weight: 900; letter-spacing: 1px; text-decoration: none; box-shadow: 0 10px 20px rgba(147, 51, 234, 0.2);" do %>
        VIEW FULL HISTORY →
      <% end %>
    </div>
    <div class="space-y-3">
      <% @recent_sales.each do |sale| %>
        <div class="flex items-center justify-between p-4 glass-style rounded-2xl bg-white/5 group hover:bg-white/10 transition-all border-none">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-lg">
              <%= sale.method == @user.sales_methods.first ? '👤' : '📡' %>
            </div>
            <div>
              <p class="text-sm font-black text-gray-800 dark:text-gray-100 tracking-tight">₦<%= number_with_delimiter(sale.amount.to_i) %> Closed</p>
              <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">
                <%= sale.method %> • <%= sale.created_at.strftime("%I:%M %p") %>
              </p>
            </div>
          </div>
          <span class="text-xs font-black text-purple-600 dark:text-purple-400 bg-purple-500/10 px-3 py-1.5 rounded-xl">+<%= sale.xp_earned %> XP</span>
        </div>
      <% end %>
      <% if @recent_sales.empty? %>
        <div class="py-12 text-center">
          <p class="text-xs font-black text-gray-400 uppercase tracking-widest">No Recent Transmissions</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

